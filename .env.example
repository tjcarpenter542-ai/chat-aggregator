# Copy this file to `.env` and fill in. Only VITE_-prefixed vars reach the browser.
# WARNING: anything in a VITE_ var is bundled into client JS and shipped to users.
# Do NOT put real secrets here — the X bearer token below is a placeholder for the stub
# only. A real deployment must proxy X through a server that holds the token.

# X (Twitter) connector — disabled by default. The connector is a no-op unless this is
# exactly the string "true".
VITE_X_ENABLED=false

# Placeholder only. The browser cannot safely use this; it exists to document intent.
VITE_X_BEARER_TOKEN=

# Comma-separated feeds to auto-load on startup, as "source:channel".
# Placeholders only — entries starting with "placeholder" are ignored. Replace with real
# channels, e.g. VITE_DEFAULT_CHANNELS=twitch:xqc,kick:trainwreckstv
VITE_DEFAULT_CHANNELS=twitch:placeholder_channel,kick:placeholder_channel
